# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/ticket-booking
# Atlas example: mongodb+srv://<user>:<pass>@cluster0.mongodb.net/ticket-booking

# Redis (used by BullMQ for waitlist offer timers & hold expiry jobs)
REDIS_URL=redis://127.0.0.1:6379
# Upstash example: rediss://default:<password>@<endpoint>.upstash.io:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Seat hold TTL (minutes)
SEAT_HOLD_TTL_MINUTES=10

# Waitlist offer TTL (minutes) - time customer has to complete booking after being offered a seat
WAITLIST_OFFER_TTL_MINUTES=15

# Email (Nodemailer - Gmail SMTP example, use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="Ticket Booking <youremail@gmail.com>"
